---
// Contact & quote request page
import Layout from '../layouts/Layout.astro';
import Nav    from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Get a Free Quote | Teton Exterior Lighting — Idaho Falls, ID"
  description="Request a free, no-obligation quote for permanent LED exterior lighting. Based in Idaho Falls, Teton Exterior Lighting serves Southeast Idaho, Jackson Hole, Salt Lake City, Boise, and the surrounding region."
>
  <Nav />

  <section class="contact-hero">
    <div class="container">
      <span class="eyebrow">Free Quote — No Obligation</span>
      <div class="gold-rule"></div>
      <h1 class="section-title">Let's Talk About<br />Your Home</h1>
      <p class="section-body">
        Fill out the form and we'll reach out within 24 hours to schedule your free quote.
        Most quotes take less than 30 minutes — and there's zero pressure to commit.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-grid">

      <!-- Form -->
      <div class="form-wrap reveal">
        <form
          name="quote-request"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/success"
        >
          <input type="hidden" name="form-name" value="quote-request" />
          <p style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="form-row">
            <div class="form-group">
              <label for="firstName">First Name *</label>
              <input type="text" id="firstName" name="firstName" placeholder="John" required />
            </div>
            <div class="form-group">
              <label for="lastName">Last Name *</label>
              <input type="text" id="lastName" name="lastName" placeholder="Smith" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" placeholder="(208) 555-0100" required />
            </div>
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="john@example.com" />
            </div>
          </div>

          <div class="form-group">
            <label for="address">Home Address</label>
            <input type="text" id="address" name="address" placeholder="123 Main St, Idaho Falls, ID" />
          </div>

          <div class="form-group">
            <label for="homeType">Home Type</label>
            <select id="homeType" name="homeType">
              <option value="">Select one...</option>
              <option>Single-story home</option>
              <option>Two-story home</option>
              <option>Multi-story home</option>
              <option>Commercial property</option>
              <option>Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="hear">How did you hear about us?</label>
            <select id="hear" name="hear">
              <option value="">Select one...</option>
              <option>Google Search</option>
              <option>Google Maps</option>
              <option>Facebook</option>
              <option>Neighbor / Friend Referral</option>
              <option>Saw a home in my neighborhood</option>
              <option>Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Anything else we should know? (optional)</label>
            <textarea id="message" name="message" rows="4" placeholder="e.g., I have a two-story home with a steep roofline, or I'm interested in custom colors..."></textarea>
          </div>

          <button type="submit" class="btn btn-gold btn-lg" style="width:100%">
            Request My Free Quote →
          </button>
          <p class="form-note">No obligation. No pressure. We'll be in touch within 24 hours.</p>
        </form>
      </div>

      <!-- Contact Info Sidebar -->
      <aside class="contact-sidebar reveal">
        <div class="info-card">
          <h3>Rather Talk First?</h3>
          <p>Give us a call or text anytime during business hours.</p>
          <a href="tel:+12085579009" class="phone-link">(208) 557-9009</a>
        </div>

        <div class="info-card">
          <h3>Service Area</h3>
          <p>Based in Idaho Falls — we serve communities across the region:</p>
          <ul>
            <li>✓ Idaho Falls & Ammon</li>
            <li>✓ Rexburg & Pocatello</li>
            <li>✓ Jackson Hole, WY</li>
            <li>✓ Salt Lake City, UT</li>
            <li>✓ Boise & Twin Falls, ID</li>
            <li>✓ And surrounding communities</li>
          </ul>
        </div>

        <div class="info-card">
          <h3>Business Hours</h3>
          <ul class="hours-list">
            <li><span>Mon – Fri</span><span>8am – 6pm</span></li>
            <li><span>Saturday</span><span>9am – 4pm</span></li>
            <li><span>Sunday</span><span>Closed</span></li>
          </ul>
        </div>

        <div class="info-card trust-card">
          <p>⭐⭐⭐⭐⭐</p>
          <p class="trust-quote">"The installation team was in and out so fast. You'd never know the hardware was there during the day."</p>
          <span>— Ryan T., Pocatello</span>
        </div>
      </aside>

    </div>
  </section>

  <Footer />
</Layout>

<style>
  .contact-hero {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    padding: 140px 0 80px;
  }
  .contact-hero .section-body { margin-top: 0.75rem; }

  .contact-body {
    background: var(--surface);
    padding: var(--section-pad);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Form */
  .form-wrap {
    background: var(--surface3);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .form-group label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--silver);
    letter-spacing: 0.04em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    color: var(--white);
    font-size: 0.95rem;
    font-family: var(--font);
    transition: border-color var(--transition), background var(--transition);
    outline: none;
    width: 100%;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder { color: var(--muted); }
  .form-group select { color: var(--silver); cursor: pointer; }
  .form-group select option { background: var(--surface2); }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--accent);
    background: rgba(200,150,12,0.04);
  }
  .form-group textarea { resize: vertical; }

  .form-note {
    text-align: center;
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.75rem;
  }

  /* Sidebar */
  .contact-sidebar { display: flex; flex-direction: column; gap: 1.25rem; }

  .info-card {
    background: var(--surface3);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }

  .info-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .info-card p {
    font-size: 0.9rem;
    color: var(--silver);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }
  .info-card ul { margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .info-card li { font-size: 0.88rem; color: var(--silver); }

  .phone-link {
    display: inline-block;
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--accent);
    margin-top: 0.5rem;
    transition: color var(--transition);
  }
  .phone-link:hover { color: var(--accent-bright); }

  .hours-list { list-style: none; }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    color: var(--silver);
    padding: 0.35rem 0;
    border-bottom: 1px solid var(--border);
  }
  .hours-list li:last-child { border-bottom: none; }

  .trust-card { border-color: var(--border-gold); }
  .trust-quote {
    font-style: italic;
    font-size: 0.9rem !important;
    margin-top: 0.25rem !important;
  }
  .trust-card span { font-size: 0.8rem; color: var(--muted); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Nav    from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const updated = 'April 4, 2025';
---

<Layout
  title="Privacy Policy & Terms of Service | Teton Exterior Lighting"
  description="Privacy Policy and Terms of Service for Teton Exterior Lighting. Learn how we collect, use, and protect your information."
  noindex={true}
>
  <Nav />

  <section class="policy-hero">
    <div class="container">
      <span class="eyebrow">Legal</span>
      <div class="gold-rule"></div>
      <h1 class="section-title">Privacy Policy &<br />Terms of Service</h1>
      <p class="section-body">Last updated: {updated}</p>
    </div>
  </section>

  <section class="policy-body">
    <div class="container policy-inner">

      <!-- Table of Contents -->
      <nav class="toc">
        <h3>Contents</h3>
        <ol>
          <li><a href="#privacy">Privacy Policy</a></li>
          <li><a href="#information">Information We Collect</a></li>
          <li><a href="#use">How We Use Your Information</a></li>
          <li><a href="#sms">SMS / Text Message Communications</a></li>
          <li><a href="#sharing">Sharing of Information</a></li>
          <li><a href="#cookies">Cookies</a></li>
          <li><a href="#rights">Your Rights</a></li>
          <li><a href="#security">Security</a></li>
          <li><a href="#children">Children's Privacy</a></li>
          <li><a href="#terms">Terms of Service</a></li>
          <li><a href="#services">Services</a></li>
          <li><a href="#conduct">User Conduct</a></li>
          <li><a href="#liability">Limitation of Liability</a></li>
          <li><a href="#changes">Changes to These Policies</a></li>
          <li><a href="#contact-legal">Contact Us</a></li>
        </ol>
      </nav>

      <!-- Main content -->
      <div class="policy-content">

        <!-- ========================
             PRIVACY POLICY
        ========================= -->
        <h2 id="privacy">Privacy Policy</h2>
        <p>
          Teton Exterior Lighting ("we," "us," or "our") is committed to protecting your privacy. This Privacy
          Policy explains how we collect, use, disclose, and safeguard your information when you visit our
          website (<strong>tetonexteriorlighting.com</strong>), submit a contact form, or communicate with us
          by phone, email, or text message.
        </p>
        <p>
          Please read this policy carefully. By using our website or services, you agree to the terms
          described here. If you do not agree, please do not use our website or services.
        </p>

        <h2 id="information">1. Information We Collect</h2>
        <p>We may collect the following categories of personal information:</p>
        <ul>
          <li><strong>Contact information</strong> — first name, last name, email address, phone number, and home address</li>
          <li><strong>Property information</strong> — home type, roofline details, and other information you provide in connection with a quote request</li>
          <li><strong>Communications</strong> — records of phone calls, emails, text messages, or form submissions you send to us</li>
          <li><strong>Usage data</strong> — IP address, browser type, pages visited, and time spent on our website (collected automatically via standard web analytics)</li>
          <li><strong>Referral information</strong> — how you heard about us (e.g., Google, referral, social media)</li>
        </ul>
        <p>We collect this information when you:</p>
        <ul>
          <li>Submit a quote request or contact form on our website</li>
          <li>Call or text our business phone number</li>
          <li>Interact with us on social media</li>
          <li>Provide information during a consultation or installation</li>
        </ul>

        <h2 id="use">2. How We Use Your Information</h2>
        <p>We use the information we collect to:</p>
        <ul>
          <li>Respond to your inquiries and provide quotes for our services</li>
          <li>Schedule and complete lighting installations</li>
          <li>Send you appointment reminders, follow-up messages, and customer support communications</li>
          <li>Send you promotional offers and updates about our services, where you have consented</li>
          <li>Improve our website and customer experience</li>
          <li>Comply with applicable laws and regulations</li>
        </ul>

        <!-- ========================
             SMS — CRITICAL FOR 10DLC
        ========================= -->
        <h2 id="sms">3. SMS / Text Message Communications</h2>

        <h3>Consent to Receive Text Messages</h3>
        <p>
          By providing your mobile phone number on our website contact form or to our staff, you expressly
          consent to receive text messages (SMS/MMS) from Teton Exterior Lighting at the number you provide.
          These messages may include appointment reminders, quote follow-ups, service updates, and promotional
          offers related to our permanent LED lighting services.
        </p>
        <p>
          <strong>Message frequency may vary.</strong> Message and data rates may apply depending on your
          mobile carrier and plan.
        </p>

        <h3>How to Opt Out</h3>
        <p>
          You may opt out of receiving text messages from us at any time by replying <strong>STOP</strong> to
          any text message you receive from us. You may also text <strong>HELP</strong> for assistance or
          contact us directly at <a href="tel:+12085579009">(208) 557-9009</a> or
          <a href="mailto:tetonexteriorlighting@gmail.com">tetonexteriorlighting@gmail.com</a>.
        </p>
        <p>
          After you opt out, we will send you one final confirmation message and then stop sending
          text messages to your number, unless you re-enroll.
        </p>

        <h3>No Third-Party Sharing for SMS</h3>
        <p class="highlight-box">
          <strong>No mobile information will be shared with third parties or affiliates for marketing or
          promotional purposes.</strong> All categories of opt-out are honored. Your phone number and
          consent to receive text messages will not be sold, rented, or shared with any third party for
          their own marketing purposes.
        </p>

        <h3>Supported Carriers</h3>
        <p>
          Major U.S. wireless carriers support our messaging program, including but not limited to AT&amp;T,
          T-Mobile, Verizon, and others. Carrier support is not guaranteed. Carriers are not liable for
          delayed or undelivered messages.
        </p>

        <h2 id="sharing">4. Sharing of Information</h2>
        <p>
          We do not sell, trade, or rent your personal information to third parties. We may share your
          information only in the following limited circumstances:
        </p>
        <ul>
          <li>
            <strong>Service providers</strong> — We may share data with trusted vendors who assist in
            operating our website or delivering services (e.g., our CRM, scheduling software, or SMS
            platform). These providers are contractually required to keep your data confidential and
            use it solely to provide services on our behalf.
          </li>
          <li>
            <strong>Legal compliance</strong> — We may disclose information if required by law,
            subpoena, or other legal process, or when we believe in good faith that disclosure is
            necessary to protect our rights or the safety of others.
          </li>
          <li>
            <strong>Business transfers</strong> — In the event of a merger, acquisition, or sale of
            assets, your information may be transferred as part of that transaction.
          </li>
        </ul>
        <p>
          <strong>We will never share your personal information with third parties for their own marketing
          or advertising purposes without your explicit consent.</strong>
        </p>

        <h2 id="cookies">5. Cookies and Tracking Technologies</h2>
        <p>
          Our website may use cookies and similar tracking technologies to enhance your experience and
          analyze website traffic. You can control cookies through your browser settings. Disabling cookies
          may affect the functionality of certain parts of our site.
        </p>

        <h2 id="rights">6. Your Rights and Choices</h2>
        <p>Depending on your location, you may have the right to:</p>
        <ul>
          <li>Request access to the personal information we hold about you</li>
          <li>Request correction of inaccurate information</li>
          <li>Request deletion of your personal information</li>
          <li>Opt out of marketing communications at any time</li>
          <li>Opt out of SMS messages by replying STOP</li>
        </ul>
        <p>
          To exercise any of these rights, contact us at
          <a href="mailto:tetonexteriorlighting@gmail.com">tetonexteriorlighting@gmail.com</a> or
          <a href="tel:+12085579009">(208) 557-9009</a>.
        </p>

        <h2 id="security">7. Security</h2>
        <p>
          We implement reasonable administrative, technical, and physical safeguards to protect your
          personal information. However, no method of transmission over the internet or electronic storage
          is 100% secure, and we cannot guarantee absolute security.
        </p>

        <h2 id="children">8. Children's Privacy</h2>
        <p>
          Our services are not directed to individuals under the age of 18. We do not knowingly collect
          personal information from children. If you believe we have inadvertently collected information
          from a minor, please contact us and we will promptly delete it.
        </p>

        <div class="divider"></div>

        <!-- ========================
             TERMS OF SERVICE
        ========================= -->
        <h2 id="terms">Terms of Service</h2>
        <p>
          These Terms of Service ("Terms") govern your use of the Teton Exterior Lighting website and
          services. By accessing our website or engaging our services, you agree to these Terms.
        </p>

        <h2 id="services">9. Services</h2>
        <p>
          Teton Exterior Lighting provides permanent LED exterior lighting installation services for
          residential and commercial properties in Idaho Falls, Idaho and surrounding regions. All services
          are subject to a separate written or verbal service agreement, quote, or proposal.
        </p>
        <p>
          We reserve the right to refuse service to anyone for any reason at any time.
        </p>

        <h2 id="conduct">10. Website Use and User Conduct</h2>
        <p>You agree not to use our website to:</p>
        <ul>
          <li>Submit false, misleading, or fraudulent information</li>
          <li>Engage in any activity that could damage, disable, or impair the website</li>
          <li>Attempt to gain unauthorized access to any portion of the website or its related systems</li>
          <li>Collect or harvest personal data about other users</li>
        </ul>
        <p>
          All content on this website, including text, photos, graphics, and branding, is the property of
          Teton Exterior Lighting and may not be copied, reproduced, or distributed without our express
          written permission.
        </p>

        <h2 id="liability">11. Disclaimer and Limitation of Liability</h2>
        <p>
          Our website and its content are provided "as is" without warranties of any kind, express or
          implied. We do not warrant that the website will be uninterrupted, error-free, or free of viruses.
        </p>
        <p>
          To the fullest extent permitted by law, Teton Exterior Lighting shall not be liable for any
          indirect, incidental, special, consequential, or punitive damages arising out of your use of our
          website or services.
        </p>
        <p>
          Our total liability for any claim related to our services shall not exceed the amount paid by
          you for the specific service giving rise to the claim.
        </p>

        <h2>12. Governing Law</h2>
        <p>
          These Terms and your use of our services are governed by the laws of the State of Idaho, without
          regard to its conflict of law provisions. Any disputes shall be resolved in the courts of
          Bonneville County, Idaho.
        </p>

        <h2 id="changes">13. Changes to These Policies</h2>
        <p>
          We may update this Privacy Policy and Terms of Service from time to time. We will notify you of
          any material changes by updating the "Last updated" date at the top of this page. Your continued
          use of our website after any changes constitutes your acceptance of the updated policies.
        </p>

        <h2 id="contact-legal">14. Contact Us</h2>
        <p>
          If you have any questions about this Privacy Policy or Terms of Service, or wish to exercise any
          of your rights, please contact us:
        </p>
        <div class="contact-block">
          <p><strong>Teton Exterior Lighting</strong></p>
          <p>Idaho Falls, Idaho</p>
          <p>Phone: <a href="tel:+12085579009">(208) 557-9009</a></p>
          <p>Email: <a href="mailto:tetonexteriorlighting@gmail.com">tetonexteriorlighting@gmail.com</a></p>
          <p>Website: <a href="https://tetonexteriorlighting.com">tetonexteriorlighting.com</a></p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .policy-hero {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    padding: 140px 0 80px;
  }
  .policy-hero .section-body {
    margin-top: 0.75rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .policy-body {
    background: var(--surface);
    padding: var(--section-pad);
  }

  .policy-inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* Table of Contents */
  .toc {
    position: sticky;
    top: 130px;
    background: var(--surface3);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  .toc h3 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--silver);
    margin-bottom: 1rem;
  }
  .toc ol {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    counter-reset: none;
    list-style: decimal;
    padding-left: 1.2rem;
  }
  .toc li { font-size: 0.8rem; color: var(--muted); }
  .toc a {
    color: var(--muted);
    transition: color var(--transition);
    line-height: 1.4;
  }
  .toc a:hover { color: var(--accent); }

  /* Policy Content */
  .policy-content h2 {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--white);
    margin: 2.5rem 0 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .policy-content h2:first-child {
    margin-top: 0;
    border-top: none;
    padding-top: 0;
  }
  .policy-content h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--silver);
    margin: 1.5rem 0 0.5rem;
  }
  .policy-content p {
    font-size: 0.92rem;
    color: var(--silver);
    line-height: 1.8;
    margin-bottom: 0.9rem;
  }
  .policy-content ul,
  .policy-content ol {
    margin: 0.5rem 0 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .policy-content li {
    font-size: 0.92rem;
    color: var(--silver);
    line-height: 1.7;
  }
  .policy-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .policy-content a:hover { color: var(--accent-bright); }
  .policy-content strong { color: var(--white); }

  .highlight-box {
    background: rgba(200,150,12,0.07);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    color: var(--silver) !important;
  }

  .divider {
    border: none;
    border-top: 2px solid var(--border-gold);
    margin: 3rem 0;
    opacity: 0.4;
  }

  .contact-block {
    background: var(--surface3);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-top: 0.5rem;
  }
  .contact-block p { margin-bottom: 0.4rem !important; }

  @media (max-width: 900px) {
    .policy-inner { grid-template-columns: 1fr; }
    .toc { position: static; }
  }
</style>
